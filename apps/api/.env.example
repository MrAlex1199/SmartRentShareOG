# ─── API Environment Variables (Production) ───────────────────
# Copy this file and fill in real values before deploying
# On Render: set these in Dashboard → Environment → Environment Variables

# MongoDB Atlas (Singapore region recommended)
MONGO_URI=mongodb+srv://USER:PASS@cluster.xxxxx.mongodb.net/smartrent?retryWrites=true&w=majority

# JWT Secret (generate a strong random string)
JWT_SECRET=your-super-secret-jwt-key-change-this

# Server
PORT=3001
NODE_ENV=production

# Frontend URL (for CORS — set after Vercel deploy)
FRONTEND_URL=https://your-app.vercel.app

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# Cloudinary (image/video upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
